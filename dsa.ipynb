   "source": [
    "# write a program which is print sum of all element of the given array \n",
    "def sum(arr):\n",
    "     total = 0\n",
    "     for num in arr:\n",
    "          total += num\n",
    "     return total\n",
    "arr = [1,2,3,4,5]\n",
    "print(\"Sum of all elements in the array:\", sum(arr))\n",
    "\n"
   ]
  }
